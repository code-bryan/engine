{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "paths": {
      "@engine/ecs-core": ["./packages/ecs-core/src/index.ts"],
      "@engine/components": ["./packages/components/src/index.ts"],
      "@engine/editor": ["./packages/editor/src/index.ts"],
      "@engine/renderer": ["./packages/renderer/src/index.ts"],
      "@engine/loader": ["./packages/loader/src/index.ts"],
      "@engine/input": ["./packages/input/src/index.ts"],
      "@engine/physics": ["./packages/physics/src/index.ts"],
      "@engine/runtime": ["./packages/runtime/src/index.ts"]
    }
  }
}
