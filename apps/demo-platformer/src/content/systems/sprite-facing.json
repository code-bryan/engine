    { "id": "readVelocity", "type": "ReadComponent", "position": { "x": 460, "y": 80 }, "data": { "component": "velocity", "as": "velocity" } },
    { "id": "selectFacing", "type": "SelectFacingFromVelocity", "position": { "x": 640, "y": 80 }, "data": { "from": "velocity", "as": "facing", "left": "left", "right": "right" } },
    { "id": "storeFacing", "type": "SetComponent", "position": { "x": 820, "y": 80 }, "data": { "component": "facing", "from": "facing" } },
    { "id": "flipScale", "type": "SetTransformScaleFromFacing", "position": { "x": 1000, "y": 80 }, "data": { "facingFrom": "facing", "left": "left", "right": "right" } }
